# ===========================================
# AmkyawDev Tools - Environment Variables
# ===========================================

# --- OpenRouter (LLM) ---
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=google/gemma-4-31b-it:free
OPENROUTER_CODE_MODEL=poolside/laguna-m.1:free

# --- Qdrant (Vector DB) ---
QDRANT_URL=https://your-qdrant-instance.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION_NAME=amkyawdev-tools

# --- PostgreSQL (Aiven / Neon) ---
PSQL_CMD=postgres://avnadmin:password@your-project.aivencloud.com:21699/defaultdb?sslmode=require
DATABASE_URL=
NEON_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# --- Browserless (Headless Chrome) ---
BROWSERLESS_API_KEY=your-browserless-api-key

# --- NVIDIA NIM (Optional fallback LLM) ---
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_DEFAULT_MODEL=nvidia/nemotron-3-nano-30b-a3b
NVIDIA_CODE_MODEL=mistralai/codestral-22b-instruct-v0.1

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=https://tools-backend-mu.vercel.app
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# --- Aiven (Kafka + OpenSearch) ---
# Kafka
KAFKA_BOOTSTRAP_SERVERS=your-kafka-broker.aivencloud.com:port
KAFKA_USERNAME=avnadmin
KAFKA_PASSWORD=your-password
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-256
KAFKA_TOPIC_USER_EVENTS=amkyawdev-user-events
KAFKA_TOPIC_AGENT_EVENTS=amkyawdev-agent-events
KAFKA_TOPIC_ANALYTICS=amkyawdev-analytics

# --- Security ---
API_SECRET_KEY=change-this-to-a-random-secret
JWT_SECRET_KEY=change-this-to-another-random-secret
